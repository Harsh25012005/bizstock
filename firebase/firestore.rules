rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isDocumentOwner(ownerId) {
      return isSignedIn() && request.auth.uid == ownerId;
    }

    function belongsToBusiness(businessId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId;
    }

    // Users collection mirrors Firebase Auth users and should only be writable by the owner/admin process.
    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create, update: if isDocumentOwner(userId);
      allow delete: if false;
    }

    match /businesses/{businessId} {
      allow read, write: if belongsToBusiness(businessId);
    }

    match /products/{productId} {
      allow read, write: if belongsToBusiness(resource.data.businessId) || belongsToBusiness(request.resource.data.businessId);
    }

    match /retailers/{retailerId} {
      allow read, write: if belongsToBusiness(resource.data.businessId) || belongsToBusiness(request.resource.data.businessId);
    }

    match /orders/{orderId} {
      allow read, write: if belongsToBusiness(resource.data.businessId) || belongsToBusiness(request.resource.data.businessId);
    }

    match /payments/{paymentId} {
      allow read, write: if belongsToBusiness(resource.data.businessId) || belongsToBusiness(request.resource.data.businessId);
    }
  }
}
